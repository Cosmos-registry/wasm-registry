{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChainResponse",
  "type": "object",
  "required": [
    "endpoints"
  ],
  "properties": {
    "chain": {
      "anyOf": [
        {
          "$ref": "#/definitions/ChainMeta"
        },
        {
          "type": "null"
        }
      ]
    },
    "endpoints": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/EndpointView"
      }
    },
    "owner": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Asset": {
      "type": "object",
      "required": [
        "decimals",
        "denom",
        "display",
        "symbol"
      ],
      "properties": {
        "decimals": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "denom": {
          "type": "string"
        },
        "display": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ChainMeta": {
      "type": "object",
      "required": [
        "assets",
        "bech32_prefix",
        "chain_id",
        "chain_name",
        "explorers",
        "network_type",
        "pretty_name"
      ],
      "properties": {
        "assets": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        },
        "bech32_prefix": {
          "type": "string"
        },
        "chain_id": {
          "type": "string"
        },
        "chain_name": {
          "type": "string"
        },
        "explorers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Explorer"
          }
        },
        "network_type": {
          "$ref": "#/definitions/NetworkType"
        },
        "pretty_name": {
          "type": "string"
        },
        "website": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "EndpointKind": {
      "type": "string",
      "enum": [
        "rpc",
        "rest",
        "grpc",
        "wss"
      ]
    },
    "EndpointView": {
      "type": "object",
      "required": [
        "active",
        "chain_id",
        "endpoint_id",
        "kind",
        "normalized_url",
        "owner",
        "preferred",
        "remaining_deposit",
        "url",
        "verified"
      ],
      "properties": {
        "active": {
          "type": "boolean"
        },
        "chain_id": {
          "type": "string"
        },
        "endpoint_id": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "estimated_expiry": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "kind": {
          "$ref": "#/definitions/EndpointKind"
        },
        "normalized_url": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "preferred": {
          "type": "boolean"
        },
        "remaining_deposit": {
          "$ref": "#/definitions/Uint128"
        },
        "url": {
          "type": "string"
        },
        "verified": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "Explorer": {
      "type": "object",
      "required": [
        "kind",
        "url"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "NetworkType": {
      "type": "string",
      "enum": [
        "mainnet",
        "testnet",
        "devnet"
      ]
    },
    "Uint128": {
      "description": "A thin wrapper around u128 that is using strings for JSON encoding/decoding, such that the full u128 range can be used for clients that convert JSON numbers to floats, like JavaScript and jq.\n\n# Examples\n\nUse `from` to create instances of this and `u128` to get the value out:\n\n``` # use cosmwasm_std::Uint128; let a = Uint128::from(123u128); assert_eq!(a.u128(), 123);\n\nlet b = Uint128::from(42u64); assert_eq!(b.u128(), 42);\n\nlet c = Uint128::from(70u32); assert_eq!(c.u128(), 70); ```",
      "type": "string"
    }
  }
}
