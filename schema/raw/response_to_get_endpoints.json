{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EndpointsResponse",
  "type": "object",
  "required": [
    "endpoints"
  ],
  "properties": {
    "endpoints": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/EndpointView"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "EndpointKind": {
      "type": "string",
      "enum": [
        "rpc",
        "rest",
        "grpc",
        "wss"
      ]
    },
    "EndpointStatus": {
      "type": "string",
      "enum": [
        "online",
        "offline"
      ]
    },
    "EndpointView": {
      "type": "object",
      "required": [
        "active",
        "chain_id",
        "consecutive_failures",
        "consecutive_successes",
        "endpoint_id",
        "kind",
        "normalized_url",
        "owner",
        "preferred",
        "remaining_deposit",
        "url",
        "verification_state"
      ],
      "properties": {
        "active": {
          "type": "boolean"
        },
        "chain_id": {
          "type": "string"
        },
        "consecutive_failures": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "consecutive_successes": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "endpoint_id": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "estimated_expiry": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "kind": {
          "$ref": "#/definitions/EndpointKind"
        },
        "last_checked_at": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "last_checked_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "last_latency_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "last_status": {
          "anyOf": [
            {
              "$ref": "#/definitions/EndpointStatus"
            },
            {
              "type": "null"
            }
          ]
        },
        "last_success_at": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "normalized_url": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "preferred": {
          "type": "boolean"
        },
        "remaining_deposit": {
          "$ref": "#/definitions/Uint128"
        },
        "url": {
          "type": "string"
        },
        "verification_state": {
          "$ref": "#/definitions/VerificationState"
        }
      },
      "additionalProperties": false
    },
    "Uint128": {
      "description": "A thin wrapper around u128 that is using strings for JSON encoding/decoding, such that the full u128 range can be used for clients that convert JSON numbers to floats, like JavaScript and jq.\n\n# Examples\n\nUse `from` to create instances of this and `u128` to get the value out:\n\n``` # use cosmwasm_std::Uint128; let a = Uint128::from(123u128); assert_eq!(a.u128(), 123);\n\nlet b = Uint128::from(42u64); assert_eq!(b.u128(), 42);\n\nlet c = Uint128::from(70u32); assert_eq!(c.u128(), 70); ```",
      "type": "string"
    },
    "VerificationState": {
      "type": "string",
      "enum": [
        "unverified",
        "verified_online",
        "verified_offline"
      ]
    }
  }
}
