{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecuteMsg",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "register_chain"
      ],
      "properties": {
        "register_chain": {
          "type": "object",
          "required": [
            "chain"
          ],
          "properties": {
            "chain": {
              "$ref": "#/definitions/ChainMeta"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "update_chain_meta"
      ],
      "properties": {
        "update_chain_meta": {
          "type": "object",
          "required": [
            "chain_id",
            "update"
          ],
          "properties": {
            "chain_id": {
              "type": "string"
            },
            "update": {
              "$ref": "#/definitions/ChainMetaUpdate"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "register_endpoint"
      ],
      "properties": {
        "register_endpoint": {
          "type": "object",
          "required": [
            "chain_id",
            "endpoint"
          ],
          "properties": {
            "chain_id": {
              "type": "string"
            },
            "endpoint": {
              "$ref": "#/definitions/EndpointInput"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "top_up_endpoint"
      ],
      "properties": {
        "top_up_endpoint": {
          "type": "object",
          "required": [
            "amount",
            "chain_id",
            "endpoint_id"
          ],
          "properties": {
            "amount": {
              "$ref": "#/definitions/Uint128"
            },
            "chain_id": {
              "type": "string"
            },
            "endpoint_id": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "remove_endpoint"
      ],
      "properties": {
        "remove_endpoint": {
          "type": "object",
          "required": [
            "chain_id",
            "endpoint_id"
          ],
          "properties": {
            "chain_id": {
              "type": "string"
            },
            "endpoint_id": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "set_params"
      ],
      "properties": {
        "set_params": {
          "type": "object",
          "required": [
            "params"
          ],
          "properties": {
            "params": {
              "$ref": "#/definitions/ParamsUpdate"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "set_endpoint_flags"
      ],
      "properties": {
        "set_endpoint_flags": {
          "type": "object",
          "required": [
            "chain_id",
            "endpoint_id"
          ],
          "properties": {
            "chain_id": {
              "type": "string"
            },
            "endpoint_id": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            },
            "preferred": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "verified": {
              "type": [
                "boolean",
                "null"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  ],
  "definitions": {
    "Asset": {
      "type": "object",
      "required": [
        "decimals",
        "denom",
        "display",
        "symbol"
      ],
      "properties": {
        "decimals": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "denom": {
          "type": "string"
        },
        "display": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ChainMeta": {
      "type": "object",
      "required": [
        "assets",
        "bech32_prefix",
        "chain_id",
        "chain_name",
        "explorers",
        "network_type",
        "pretty_name"
      ],
      "properties": {
        "assets": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        },
        "bech32_prefix": {
          "type": "string"
        },
        "chain_id": {
          "type": "string"
        },
        "chain_name": {
          "type": "string"
        },
        "explorers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Explorer"
          }
        },
        "network_type": {
          "$ref": "#/definitions/NetworkType"
        },
        "pretty_name": {
          "type": "string"
        },
        "website": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "ChainMetaUpdate": {
      "type": "object",
      "properties": {
        "assets": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/Asset"
          }
        },
        "bech32_prefix": {
          "type": [
            "string",
            "null"
          ]
        },
        "chain_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "explorers": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/Explorer"
          }
        },
        "network_type": {
          "anyOf": [
            {
              "$ref": "#/definitions/NetworkType"
            },
            {
              "type": "null"
            }
          ]
        },
        "pretty_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "website": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "EndpointInput": {
      "type": "object",
      "required": [
        "deposit",
        "kind",
        "url"
      ],
      "properties": {
        "deposit": {
          "$ref": "#/definitions/Uint128"
        },
        "kind": {
          "$ref": "#/definitions/EndpointKind"
        },
        "owner": {
          "type": [
            "string",
            "null"
          ]
        },
        "url": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "EndpointKind": {
      "type": "string",
      "enum": [
        "rpc",
        "rest",
        "grpc",
        "wss"
      ]
    },
    "Explorer": {
      "type": "object",
      "required": [
        "kind",
        "url"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "NetworkType": {
      "type": "string",
      "enum": [
        "mainnet",
        "testnet",
        "devnet"
      ]
    },
    "ParamsUpdate": {
      "type": "object",
      "properties": {
        "epoch_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "max_endpoints_per_chain": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "min_endpoint_deposit": {
          "anyOf": [
            {
              "$ref": "#/definitions/Uint128"
            },
            {
              "type": "null"
            }
          ]
        },
        "rent_per_epoch": {
          "anyOf": [
            {
              "$ref": "#/definitions/Uint128"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "Uint128": {
      "description": "A thin wrapper around u128 that is using strings for JSON encoding/decoding, such that the full u128 range can be used for clients that convert JSON numbers to floats, like JavaScript and jq.\n\n# Examples\n\nUse `from` to create instances of this and `u128` to get the value out:\n\n``` # use cosmwasm_std::Uint128; let a = Uint128::from(123u128); assert_eq!(a.u128(), 123);\n\nlet b = Uint128::from(42u64); assert_eq!(b.u128(), 42);\n\nlet c = Uint128::from(70u32); assert_eq!(c.u128(), 70); ```",
      "type": "string"
    }
  }
}
