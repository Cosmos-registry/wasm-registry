{
    "name": "cosm-registry-devcontainer",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
                "tamasfe.even-better-toml",
                "vadimcn.vscode-lldb"
            ],
            "settings": {
                "editor.formatOnSave": true,
                "rust-analyzer.check.command": "clippy"
            }
        }
    },
    "postCreateCommand": "rustup target add wasm32-unknown-unknown && cargo fetch",
    "remoteUser": "vscode"
}
